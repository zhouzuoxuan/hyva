<?php
/** @var \Lencarta\Cms\Block\Widget\UspList $block */
$title = $block->getField('title');
$items = $block->getItemsField('items');
$columns = $block->getField('columns', '3');
$gridClass = [
    '1' => 'md:grid-cols-1',
    '2' => 'md:grid-cols-2',
    '3' => 'md:grid-cols-3',
][$columns] ?? 'md:grid-cols-3';
?>
<?php if ($title !== '' || $items): ?>
<section class="rounded-3xl bg-white p-6 md:p-8">
    <?php if ($title !== ''): ?>
        <h2 class="text-2xl font-semibold leading-tight md:text-3xl"><?= $block->escapeHtml($title) ?></h2>
    <?php endif; ?>
    <?php if ($items): ?>
        <ul class="mt-6 grid gap-4 <?= $block->escapeHtmlAttr($gridClass) ?>">
            <?php foreach ($items as $item): ?>
                <li class="rounded-2xl border border-slate-200 bg-slate-50 p-5 text-sm leading-6 text-slate-700">
                    <?= $block->escapeHtml($item) ?>
                </li>
            <?php endforeach; ?>
        </ul>
    <?php endif; ?>
</section>
<?php endif; ?>
