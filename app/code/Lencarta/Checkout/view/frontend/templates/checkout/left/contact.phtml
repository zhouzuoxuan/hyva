<section>
    <div class="flex items-center justify-between border-b border-slate-200 pb-4">
        <h2 class="text-[clamp(1.7rem,2.4vw,2.5rem)] font-semibold tracking-tight text-slate-900">
            Contact Information
        </h2>

        <template x-if="emailSaveState === 'saving'">
            <span class="text-xs font-semibold text-amber-700">Saving…</span>
        </template>
        <template x-if="emailSaveState === 'saved'">
            <span class="text-xs font-semibold text-emerald-700">Saved</span>
        </template>
        <template x-if="emailSaveState === 'error'">
            <span class="text-xs font-semibold text-rose-700">Check email</span>
        </template>
    </div>

    <div class="pt-6">
        <label class="block">
            <span class="mb-1.5 block text-xs font-medium text-slate-700">E-mail address</span>
            <input
                type="email"
                x-model="email"
                @input="markEmailDirty()"
                @change="queueEmailAutosave('change')"
                @blur="queueEmailAutosave('blur')"
                class="w-full border border-slate-300 bg-white px-3 py-3 text-base outline-none transition placeholder:text-slate-400 focus:border-slate-900"
                placeholder="Enter e-mail address"
                autocomplete="email"
            >
        </label>

        <p class="mt-3 text-sm text-slate-600">
            You can create an account after checkout.
        </p>
