<?php
/** @var \Magento\Framework\View\Element\Template $block */
$label = (string) $block->getData('label');
$variant = (string) ($block->getData('variant') ?: 'default');
$classes = [
    'default' => 'bg-gray-100 text-gray-800',
    'primary' => 'bg-black text-white',
    'success' => 'bg-green-100 text-green-800',
    'warning' => 'bg-yellow-100 text-yellow-800',
];
$badgeClass = $classes[$variant] ?? $classes['default'];
?>
<?php if ($label !== ''): ?>
    <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium <?= $block->escapeHtmlAttr($badgeClass) ?>">
        <?= $block->escapeHtml($label) ?>
    </span>
<?php endif; ?>
