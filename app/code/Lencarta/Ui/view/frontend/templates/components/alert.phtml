<?php
/** @var \Magento\Framework\View\Element\Template $block */
$type = (string) ($block->getData('type') ?: 'info');
$title = (string) $block->getData('title');
$message = (string) $block->getData('message');
$classes = [
    'info' => 'border-blue-200 bg-blue-50 text-blue-900',
    'success' => 'border-green-200 bg-green-50 text-green-900',
    'warning' => 'border-yellow-200 bg-yellow-50 text-yellow-900',
    'error' => 'border-red-200 bg-red-50 text-red-900',
];
$alertClass = $classes[$type] ?? $classes['info'];
?>
<div class="rounded-xl border p-4 <?= $block->escapeHtmlAttr($alertClass) ?>">
    <?php if ($title !== ''): ?>
        <div class="mb-1 font-semibold"><?= $block->escapeHtml($title) ?></div>
    <?php endif; ?>
    <?php if ($message !== ''): ?>
        <div class="text-sm leading-6"><?= $block->escapeHtml($message) ?></div>
    <?php endif; ?>
</div>
