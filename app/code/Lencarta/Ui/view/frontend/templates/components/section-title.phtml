<?php
/** @var \Magento\Framework\View\Element\Template $block */
$eyebrow = (string) $block->getData('eyebrow');
$title = (string) $block->getData('title');
$description = (string) $block->getData('description');
$align = (string) ($block->getData('align') ?: 'left');
$alignment = $align === 'center' ? 'text-center' : 'text-left';
?>
<div class="<?= $block->escapeHtmlAttr($alignment) ?>">
    <?php if ($eyebrow !== ''): ?>
        <div class="mb-2 text-xs font-semibold uppercase tracking-[0.15em] text-gray-500"><?= $block->escapeHtml($eyebrow) ?></div>
    <?php endif; ?>
    <?php if ($title !== ''): ?>
        <h2 class="text-2xl font-semibold leading-tight md:text-3xl"><?= $block->escapeHtml($title) ?></h2>
    <?php endif; ?>
    <?php if ($description !== ''): ?>
        <div class="mt-3 text-sm leading-6 text-gray-700 md:text-base"><?= $block->escapeHtml($description) ?></div>
    <?php endif; ?>
</div>
