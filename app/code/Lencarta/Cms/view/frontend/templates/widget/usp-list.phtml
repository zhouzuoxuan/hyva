<?php
/** @var \Lencarta\Cms\Block\Widget\UspList $block */
$title = (string) $block->getData('title');
$items = $block->getItems();
$columns = (string) ($block->getData('columns') ?: '1');
$gridClass = [
    '1' => 'grid-cols-1',
    '2' => 'md:grid-cols-2',
    '3' => 'md:grid-cols-2 lg:grid-cols-3',
][$columns] ?? 'grid-cols-1';
?>
<?php if ($title !== '' || $items): ?>
    <section class="rounded-2xl bg-gray-50 p-6 md:p-8">
        <?php if ($title !== ''): ?>
            <h2 class="mb-5 text-2xl font-semibold leading-tight"><?= $block->escapeHtml($title) ?></h2>
        <?php endif; ?>
        <?php if ($items): ?>
            <div class="grid gap-4 <?= $block->escapeHtmlAttr($gridClass) ?>">
                <?php foreach ($items as $item): ?>
                    <div class="rounded-xl bg-white p-4 shadow-sm">
                        <div class="text-sm leading-6 text-gray-800"><?= $block->escapeHtml($item) ?></div>
                    </div>
                <?php endforeach; ?>
            </div>
        <?php endif; ?>
    </section>
<?php endif; ?>
