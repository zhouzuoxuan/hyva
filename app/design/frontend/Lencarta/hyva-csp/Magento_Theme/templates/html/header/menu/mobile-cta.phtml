<?php
/**
 * Mobile CTA rendered from Lencarta_Header configuration.
 */

declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Lencarta\Header\ViewModel\HeaderConfig;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

/** @var Template $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */

/** @var HeaderConfig $headerConfig */
$headerConfig = $viewModels->require(HeaderConfig::class);

if (!$headerConfig->isMobileCtaEnabled()) {
    return '';
}
?>
<div class="px-6 py-6">
    <a
        href="<?= $escaper->escapeUrl($headerConfig->getMobileCtaUrl()) ?>"
        class="btn btn-primary inline-flex w-full justify-center"
    >
        <?= $escaper->escapeHtml($headerConfig->getMobileCtaLabel()) ?>
    </a>
</div>
