<?php
declare(strict_types=1);

use Lencarta\PaymentPaypal\ViewModel\PaypalConfig;
use Magento\Framework\View\Element\Template;

/** @var Template $block */
/** @var PaypalConfig $viewModel */
$viewModel = $block->getData('view_model');

$config = [
    'enabled' => $viewModel->isEnabled(),
    'clientId' => $viewModel->getClientId(),
    'sdkUrl' => $viewModel->getSdkBaseUrl(),
    'currency' => $viewModel->getCurrency(),
    'intent' => 'capture',
    'formKey' => $viewModel->getFormKey(),
    'createOrderUrl' => $viewModel->getCreateOrderUrl(),
    'syncOrderUrl' => $viewModel->getSyncOrderUrl(),
    'invalidateOrderUrl' => $viewModel->getInvalidateOrderUrl(),
    'captureOrderUrl' => $viewModel->getCaptureUrl(),
    'captureUrl' => $viewModel->getCaptureUrl(),
    'webhookUrl' => $viewModel->getWebhookUrl(),
    'successUrl' => $viewModel->getSuccessUrl(),
    'buttonColor' => $viewModel->getButtonColor(),
    'buttonShape' => $viewModel->getButtonShape(),
    'buttonLabel' => $viewModel->getButtonLabel(),
    'button' => [
        'color' => $viewModel->getButtonColor(),
        'shape' => $viewModel->getButtonShape(),
        'label' => $viewModel->getButtonLabel(),
    ],
    'i18n' => [
        'syncError' => (string) __('Unable to sync PayPal order.'),
        'createOrderError' => (string) __('Unable to create PayPal order.'),
        'finalizeError' => (string) __('Unable to finalize PayPal payment.'),
        'genericError' => (string) __('PayPal error'),
    ],
];

$json = json_encode(
    $config,
    JSON_UNESCAPED_SLASHES
    | JSON_UNESCAPED_UNICODE
    | JSON_HEX_TAG
    | JSON_HEX_APOS
    | JSON_HEX_AMP
    | JSON_HEX_QUOT
);
?>
<div
    id="lencarta-paypal-config"
    data-config="<?= $block->escapeHtmlAttr((string) $json) ?>"
    hidden
></div>
