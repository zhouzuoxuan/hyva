<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="topmenu_mobile">
            <block
                name="topmenu_mobile.currency-switcher"
                as="currency-switcher"
                template="Magento_Directory::header/menu/currency.phtml"
            />
        </referenceBlock>

        <referenceContainer name="before.body.end">
            <block name="currency-data" template="Magento_Directory::page/currency-data.phtml"/>
        </referenceContainer>
    </body>
</page>
