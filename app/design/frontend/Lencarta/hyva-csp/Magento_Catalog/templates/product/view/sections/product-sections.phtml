declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HyvaCsp;
use Hyva\Theme\ViewModel\HeroiconsSolid;
use Magento\Catalog\Block\Product\View\Details;
use Magento\Framework\Escaper;

/** @var Details $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */

$heroiconsSolid = $viewModels->require(HeroiconsSolid::class);
/** Safety: ensure CSP view model exists even if not auto-injected */
$hyvaCsp = $viewModels->require(HyvaCsp::class);

$divider = $block->getDivider() !== null ? (bool) $block->getDivider() : true;
$sectionIsOpen = '';
?>

<div x-data="initProductSections" class="py-3 px-6 bg-gray-100 product-content-bootstrap-lite">
    <nav
        class="product-sections-tabs hidden lg:flex pb-6 snap overflow-x-auto overscroll-x-contain"
        aria-label="<?= $escaper->escapeHtml(__('Navigate to Product Section')) ?>"
        x-show="items.length"
        x-cloak
    >
        <template x-for="tab in items" :key="tab.id">
            <button
                type="button"
                class="product-sections-tab relative flex-auto pt-1 pb-3 px-3 border-b whitespace-nowrap font-bold
                       aria-expanded:text-blue-700 aria-expanded:border-current aria-expanded:after:border-inherit
                       after:absolute after:inset-x-0 after:bottom-0 after:border-b-2 after:border-transparent"
                :aria-expanded="sectionTabIsOpen($el, tab)"
                :aria-controls="tab.id"
                @click="openSectionTab(tab)"
                x-html="getTabLabel(tab)"
            ></button>
        </template>
    </nav>

    <div
        x-ref="accordion"
        <?php if ($divider): ?>class="divide-y lg:divide-y-0"<?php endif; ?>
        style="min-height: 500px"
    >
        <?php
        $productSectionIndex = 0;
        foreach ($block->getGroupSortedChildNames('detailed_info', '') as $sectionName):
            $sectionBlock = $block->getLayout()->getBlock($sectionName);
            if (!$sectionBlock) {
                continue;
            }

            $sectionHtml = (string) $sectionBlock->toHtml();
            $sectionTitle = (string) ($sectionBlock->getTitle() ?: $sectionName);
            $sectionId = str_replace('.', '-', (string) $sectionBlock->getNameInLayout());

            if (trim($sectionHtml) === '') {
                continue;
            }

            if ($productSectionIndex === 0) {
                $sectionIsOpen = $sectionId;
            }
            ?>
            <details
                id="<?= $escaper->escapeHtmlAttr($sectionId) ?>"
                data-name="<?= $escaper->escapeHtmlAttr($sectionTitle) ?>"
                class="group scroll-mt-8 lg:scroll-mt-24"
                :open="sectionItemIsOpen($el)"
            >
                <summary
                    @click.prevent="openSectionCollapse($el)"
                    class="flex [&::-webkit-details-marker]:hidden lg:hidden w-full items-center justify-between py-3 text-lg font-bold group-open:text-blue-700"
                >
                    <span><?= $escaper->escapeHtml($sectionTitle) ?></span>
                    <span class="transition-transform group-open:rotate-180">
                        <?= $heroiconsSolid->chevronDownHtml('', 20, 20, ["aria-hidden" => true]) ?>
                    </span>
                </summary>

                <div data-id="<?= $escaper->escapeHtmlAttr($sectionId) ?>" x-show="sectionItemIsOpen($el)" x-collapse>
                    <div class="pb-3">
                        <?= /** @noEscape */ $sectionHtml ?>
                    </div>
                </div>
            </details>
            <?php
            $productSectionIndex++;
        endforeach;
        ?>
    </div>

    <script>
        function initProductSections() {
            return {
                items: [],
                currentOpen: '<?= /** @noEscape */ $sectionIsOpen ?>',
                init() {
                    // remove min height once we have JS
                    if (this.$refs.accordion) {
                        this.$refs.accordion.style.minHeight = null;
                        this.items = Array.from(this.$refs.accordion.querySelectorAll('details[id]'));
                    }
                },
                openSectionTab(tab) {
                    this.openSectionItem(tab?.id);
                },
                openSectionCollapse(el) {
                    const details = el?.closest('details');
                    const targetId = details?.id;
                    if (!targetId) return;
                    this.openSectionItem(targetId);
                },
                openSectionItem(id) {
                    this.currentOpen = id || this.currentOpen || '<?= /** @noEscape */ $sectionIsOpen ?>';
                    if (!this.currentOpen) return;

                    this.$nextTick(() => {
                        const target = document.getElementById(this.currentOpen);
                        if (target) {
                            target.scrollIntoView({ behavior: "smooth", block: "nearest", inline: "nearest" });
                        }
                    });
                },
                sectionTabIsOpen(el, tab) {
                    return this.currentOpen === tab?.id;
                },
                sectionItemIsOpen(el) {
                    const id = el?.id || el?.dataset?.id;
                    return this.currentOpen === id;
                },
                getTabLabel(tab) {
                    return tab?.dataset?.name || '';
                }
            }
        }

        window.addEventListener('alpine:init', () => {
            Alpine.data('initProductSections', initProductSections);
        }, { once: true });
    </script>
    <?php $hyvaCsp->registerInlineScript() ?>

    <noscript>
        <style>details[data-name] summary { display: flex }</style>
    </noscript>
</div>
