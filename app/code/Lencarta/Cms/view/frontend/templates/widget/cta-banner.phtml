<?php
/** @var \Lencarta\Cms\Block\Widget\CtaBanner $block */
$eyebrow = $block->getField('eyebrow');
$title = $block->getField('title');
$contentHtml = $block->getHtmlField('content');
$buttonLabel = $block->getField('button_label');
$buttonUrl = $block->getField('button_url');
$desktopImage = $block->getField('desktop_image');
$mobileImage = $block->getPictureFallback('mobile_image', 'desktop_image');
$imageAlt = $block->getField('image_alt', $title);
$contentPosition = $block->getField('content_position', 'right-center');
$overlayStyle = $block->getField('overlay_style', 'dark');
$overlayOpacity = $block->getField('overlay_opacity', '35');
$textScheme = $block->getField('text_scheme', 'inherit');
$buttonStyle = $block->getField('button_style', 'primary');
$themeVariant = $block->getField('theme_variant', 'soft');

$positionClasses = [
    'left-top' => 'items-start justify-start text-left',
    'left-center' => 'items-center justify-start text-left',
    'left-bottom' => 'items-end justify-start text-left',
    'center-center' => 'items-center justify-center text-center',
    'right-top' => 'items-start justify-end text-left',
    'right-center' => 'items-center justify-end text-left',
    'right-bottom' => 'items-end justify-end text-left',
];
$contentContainerClass = $positionClasses[$contentPosition] ?? $positionClasses['right-center'];

$overlayBg = [
    'dark' => 'bg-slate-950',
    'light' => 'bg-white',
    'brand' => 'bg-slate-900',
    'none' => 'bg-transparent',
];
$overlayOpacityClass = [
    '20' => 'opacity-20',
    '35' => 'opacity-35',
    '50' => 'opacity-50',
    '65' => 'opacity-65',
];

$fallbackWrapperClass = [
    'light' => 'bg-white border border-slate-200',
    'soft' => 'bg-slate-50',
    'dark' => 'bg-slate-900 text-white',
][$themeVariant] ?? 'bg-slate-900 text-white';

$hasImage = $desktopImage !== '';
$effectiveTextScheme = $textScheme === 'inherit'
    ? ($hasImage ? 'light' : ($themeVariant === 'dark' ? 'light' : 'dark'))
    : $textScheme;
$textClasses = $block->getCtaTextSchemeClasses($effectiveTextScheme, $themeVariant);
$buttonClass = $block->getButtonStyleClasses($buttonStyle, 'cta', $effectiveTextScheme === 'brand' ? 'dark' : $effectiveTextScheme);
?>
<section class="<?= $hasImage ? 'relative isolate overflow-hidden rounded-3xl' : 'rounded-3xl p-6 md:p-8 lg:p-10 ' . $block->escapeHtmlAttr($fallbackWrapperClass) ?>">
    <?php if ($hasImage): ?>
        <div class="absolute inset-0">
            <picture>
                <?php if ($mobileImage !== '' && $mobileImage !== $desktopImage): ?>
                    <source media="(max-width: 767px)" srcset="<?= $block->escapeUrl($mobileImage) ?>">
                <?php endif; ?>
                <img src="<?= $block->escapeUrl($desktopImage) ?>"
                     alt="<?= $block->escapeHtmlAttr($imageAlt) ?>"
                     loading="lazy"
                     class="h-full w-full object-cover" />
            </picture>
        </div>
        <?php if ($overlayStyle !== 'none'): ?>
            <div class="absolute inset-0 <?= $block->escapeHtmlAttr(($overlayBg[$overlayStyle] ?? 'bg-slate-950') . ' ' . ($overlayOpacityClass[$overlayOpacity] ?? 'opacity-35')) ?>"></div>
        <?php endif; ?>
        <div class="relative z-10 flex min-h-[320px] p-6 md:min-h-[420px] md:p-8 lg:p-10 <?= $block->escapeHtmlAttr($contentContainerClass) ?>">
            <div class="w-full max-w-xl rounded-2xl">
                <?php if ($eyebrow !== ''): ?>
                    <div class="mb-3 text-xs font-semibold uppercase tracking-[0.2em] <?= $block->escapeHtmlAttr($textClasses['eyebrow']) ?>">
                        <?= $block->escapeHtml($eyebrow) ?>
                    </div>
                <?php endif; ?>
                <?php if ($title !== ''): ?>
                    <h2 class="<?= $block->escapeHtmlAttr($textClasses['title']) ?> text-3xl font-semibold leading-tight md:text-4xl"><?= $block->escapeHtml($title) ?></h2>
                <?php endif; ?>
                <?php if ($contentHtml !== ''): ?>
                    <div class="prose mt-4 max-w-none text-base leading-7 <?= $block->escapeHtmlAttr($textClasses['description']) ?>">
                        <?= /* @noEscape */ $contentHtml ?>
                    </div>
                <?php endif; ?>
                <?php if ($buttonLabel !== '' && $buttonUrl !== ''): ?>
                    <div class="mt-6">
                        <a href="<?= $block->escapeUrl($buttonUrl) ?>"
                           class="inline-flex items-center justify-center rounded-xl px-5 py-3 text-sm font-medium transition <?= $block->escapeHtmlAttr($buttonClass) ?>">
                            <?= $block->escapeHtml($buttonLabel) ?>
                        </a>
                    </div>
                <?php endif; ?>
            </div>
        </div>
    <?php else: ?>
        <?php if ($eyebrow !== ''): ?>
            <div class="mb-3 text-xs font-semibold uppercase tracking-[0.2em] <?= $themeVariant === 'dark' ? 'text-slate-300' : 'text-slate-500' ?>">
                <?= $block->escapeHtml($eyebrow) ?>
            </div>
        <?php endif; ?>
        <?php if ($title !== ''): ?>
            <h2 class="text-3xl font-semibold leading-tight md:text-4xl <?= $themeVariant === 'dark' ? 'text-white' : 'text-slate-950' ?>"><?= $block->escapeHtml($title) ?></h2>
        <?php endif; ?>
        <?php if ($contentHtml !== ''): ?>
            <div class="prose prose-slate mt-4 max-w-none text-base leading-7 <?= $themeVariant === 'dark' ? 'text-slate-200' : 'text-slate-700' ?>">
                <?= /* @noEscape */ $contentHtml ?>
            </div>
        <?php endif; ?>
        <?php if ($buttonLabel !== '' && $buttonUrl !== ''): ?>
            <div class="mt-6">
                <a href="<?= $block->escapeUrl($buttonUrl) ?>"
                   class="inline-flex items-center justify-center rounded-xl px-5 py-3 text-sm font-medium transition <?= $themeVariant === 'dark' ? 'bg-white text-slate-950 hover:bg-slate-100' : 'bg-slate-950 text-white hover:bg-slate-800' ?>">
                    <?= $block->escapeHtml($buttonLabel) ?>
                </a>
            </div>
        <?php endif; ?>
    <?php endif; ?>
</section>
