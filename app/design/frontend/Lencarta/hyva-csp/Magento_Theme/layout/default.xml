<?xml version="1.0"?>

<page
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd"
>
    <body>
        <referenceBlock name="messages">
            <arguments>
                <argument name="display_mode" xsi:type="string">tag</argument> <!-- Notification appearance (default/blank/tag) -->
                <argument name="show_icon" xsi:type="boolean">true</argument> <!-- Show icon (true/false) -->
            </arguments>
        </referenceBlock>
    </body>
</page>
