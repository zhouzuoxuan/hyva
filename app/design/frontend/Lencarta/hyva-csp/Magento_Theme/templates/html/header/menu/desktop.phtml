use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HyvaCsp;
use Hyva\Theme\ViewModel\HeroiconsSolid;
use Hyva\Theme\ViewModel\Navigation;
use Magento\Framework\View\Element\Template;
use Magento\Framework\Escaper;
use Magento\Cms\Block\BlockByIdentifier as CmsBlock;

/** @var Template $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */
/** @var HyvaCsp $hyvaCsp */

/** @var Navigation $viewModelNavigation */
$viewModelNavigation = $viewModels->require(Navigation::class, $block);

/** @var HeroiconsSolid $heroiconsSolid */
$heroiconsSolid = $viewModels->require(HeroiconsSolid::class);

$canOpenOnHover = $block->getOpenTopLevelMenuOnHover();
$showTopLevelAllLink = $block->getShowTopLevelAllLink() !== null ? $block->getShowTopLevelAllLink() : true;
$topMenuCtaItem = $block->getTopMenuCtaItem();

// Order is important here: 1. build the menu data, 2. then set the cache tags from the view model identities
$menu = $viewModelNavigation->getNavigation(5);
$block->setData('cache_tags', $viewModelNavigation->getIdentities());

$menuLayoutMap = array_merge(
    [
        // 'category-node-20' => 'editorial_cards',
        // 'category-node-11' => 'catalog_columns',
    ],
    (array) $block->getData('menu_layout_map')
);

$normalizeMenuEntityId = static function (string $menuItemId): string {
    return str_replace('-node', '', $menuItemId);
};

$renderCmsBlock = static function (string $identifier) use ($block): string {
    return trim((string) $block->getLayout()
        ->createBlock(CmsBlock::class)
        ->setIdentifier($identifier)
        ->toHtml());
};
?>

<nav
    class="navigation hidden lg:block"
    aria-label="<?= $escaper->escapeHtmlAttr(__('Main menu')) ?>"
    x-data="initMenuDesktop"
    x-ref="nav-desktop"
    @load.window="setActiveMenu"
>
    <ul class="flex flex-wrap gap-x-8">
        <?php foreach ($menu as $item): ?>
            <?php if (!empty($item['childData'])): ?>
                <?php
                $subMenuItems = array_values($item['childData']);
                $menuEntityId = $normalizeMenuEntityId($item['id']);
                $menuId = 'desktop-menu-' . $menuEntityId;
                $panels = [];
                $hasEditorialBlocks = false;

                foreach ($subMenuItems as $subMenuIndex => $subMenu) {
                    $subMenuPanelId = $menuId . '-sub-' . $subMenuIndex;
                    $subMenuEntityId = $normalizeMenuEntityId($subMenu['id']);
                    $editorialBlockHtml = '';

                    foreach (
                        [
                            $menuId . '-' . $subMenuEntityId . '-editorial',
                            'desktop-menu-' . $subMenuEntityId . '-editorial',
                        ] as $editorialBlockIdentifier
                    ) {
                        $editorialBlockHtml = $renderCmsBlock($editorialBlockIdentifier);
                        if ($editorialBlockHtml !== '') {
                            $hasEditorialBlocks = true;
                            break;
                        }
                    }

                    $panels[] = [
                        'item' => $subMenu,
                        'panel_id' => $subMenuPanelId,
                        'editorial_block_html' => $editorialBlockHtml,
                    ];
                }

                $menuLayoutType = $menuLayoutMap[$item['id']]
                    ?? $menuLayoutMap[$menuEntityId]
                    ?? $menuLayoutMap[$menuId]
                    ?? ($hasEditorialBlocks ? 'editorial_cards' : 'catalog_columns');
                $firstSubMenuId = $panels[0]['panel_id'] ?? null;
                $featureBlockHtml = $menuLayoutType === 'catalog_columns' ? $renderCmsBlock($menuId) : '';
                ?>
                <li
                    class="level-0"
                    x-data="initMenuDesktopItem('<?= $escaper->escapeJs($firstSubMenuId) ?>')"
                    @click.outside="close"
                    @keydown.escape="close"
                    <?php if ($canOpenOnHover): ?>
                        @mouseenter="canHoverOpen"
                        @mouseleave="canHoverClose"
                    <?php endif ?>
                >
                    <button
                        type="button"
                        class="level-0 group inline-flex items-center gap-1 pt-4 pb-[calc(theme(padding.4)_-_3px)]
                            border-b-[3px] border-transparent hover:border-blue-500 transition
                            aria-expanded:text-blue-500 aria-expanded:border-blue-500
                            data-[has-current]:aria-expanded:border-blue-500
                            data-[has-current]:border-slate-400 data-[has-current]:hover:border-blue-500"
                        @click="toggle"
                        aria-expanded="false"
                        :aria-expanded="open"
                        aria-controls="<?= $escaper->escapeHtml($menuId) ?>"
                    >
                        <?= $escaper->escapeHtml($item['name']) ?>
                        <?= $heroiconsSolid->chevronDownHtml(
                            'transition group-aria-expanded:rotate-180 text-slate-400 group-aria-expanded:text-inherit',
                            16,
                            16,
                            ['aria-hidden' => 'true']
                        ) ?>
                    </button>
                    <div
                        id="<?= $escaper->escapeHtml($menuId) ?>"
                        class="header-mega-menu z-30 absolute min-h-64 border-t border-slate-100
                            rounded-b-md bg-white shadow-md overflow-hidden"
                        x-show="open"
                        x-transition
                        x-cloak
                    >
                        <div class="header-mega-menu__inner container mx-auto py-6">
                            <div class="header-mega-menu__layout">
                            <nav
                                class="header-mega-menu__sidebar"
                                aria-label="<?= $escaper->escapeHtmlAttr(__('%1 categories', $item['name'])) ?>"
                            >
                                <ul class="header-mega-menu__nav">
                                    <?php foreach ($panels as $panel): ?>
                                        <?php
                                        $subMenu = $panel['item'];
                                        $subMenuId = $panel['panel_id'];
                                        ?>
                                        <li>
                                            <button
                                                type="button"
                                                class="header-mega-menu__nav-item"
                                                data-submenu-id="<?= $escaper->escapeHtmlAttr($subMenuId) ?>"
                                                @mouseenter="setActiveSubMenu('<?= $escaper->escapeJs($subMenuId) ?>')"
                                                @focus="setActiveSubMenu('<?= $escaper->escapeJs($subMenuId) ?>')"
                                                @click.prevent="setActiveSubMenu('<?= $escaper->escapeJs($subMenuId) ?>')"
                                                :class="{ 'is-active': activeSubMenu === '<?= $escaper->escapeJs($subMenuId) ?>' }"
                                            >
                                                <span><?= $escaper->escapeHtml($subMenu['name']) ?></span>
                                                <?php if (!empty($subMenu['childData'])): ?>
                                                    <?= $heroiconsSolid->chevronRightHtml('shrink-0', 18, 18, ['aria-hidden' => 'true']) ?>
                                                <?php endif; ?>
                                            </button>
                                        </li>
                                    <?php endforeach; ?>
                                </ul>
                                <?php if ($showTopLevelAllLink): ?>
                                    <div class="header-mega-menu__all-link">
                                        <a
                                            href="<?= $escaper->escapeUrl($item['url']) ?>"
                                            class="hover:underline aria-[current=page]:underline"
                                        ><?= $escaper->escapeHtml(__('See all %1', $item['name'])) ?></a>
                                    </div>
                                <?php endif; ?>
                            </nav>

                            <?= /** @noEscape */ $block->getLayout()
                                ->createBlock(Template::class)
                                ->setTemplate(
                                    $menuLayoutType === 'editorial_cards'
                                        ? 'Magento_Theme::html/header/menu/desktop/editorial.phtml'
                                        : 'Magento_Theme::html/header/menu/desktop/catalog.phtml'
                                )
                                ->setData('panels', $panels)
                                ->setData('feature_block_html', $featureBlockHtml)
                                ->toHtml() ?>
                            </div>
                        </div>
                    </div>
                </li>
            <?php else: ?>
                <li>
                    <a
                        href="<?= $escaper->escapeUrl($item['url']) ?>"
                        title="<?= $escaper->escapeHtmlAttr($item['name']) ?>"
                        class="level-0 inline-flex items-center pt-4 pb-[calc(theme(padding.4)_-_3px)] border-b-[3px]
                            border-transparent hover:border-blue-500
                            aria-[current=page]:border-slate-400 aria-[current=page]:hover:border-blue-500
                            <?= $item['name'] === $topMenuCtaItem ? 'text-red-700' : '' ?>"
                    >
                        <?= $escaper->escapeHtml($item['name']) ?>
                    </a>
                </li>
            <?php endif; ?>
        <?php endforeach; ?>
    </ul>
</nav>
<script>
    function initMenuDesktop() {
        return {
            setActiveMenu() {
                Array.from(this.$root.querySelectorAll('a'))
                    .filter(link => link.href === window.location.href.split('?')[0])
                    .forEach(item => {
                        item.setAttribute('aria-current', 'page');

                        for (let level = 0; level < 3; level++) {
                            const closestMenu = item.closest(`.level-${level}`);

                            if (closestMenu) {
                                const button = closestMenu.querySelector('button');
                                if (button) {
                                    button.setAttribute('data-has-current', '');
                                }
                            }
                        }
                    }
                );
            }
        }
    }

    function initMenuDesktopItem(initialSubMenu = null) {
        return {
            open: false,
            activeSubMenu: initialSubMenu,
            setActiveSubMenu(subMenuId) {
                this.activeSubMenu = subMenuId;
            },
            canHover(func) {
                return window.matchMedia('(hover: hover) and (pointer: fine)').matches;
            },
            canHoverOpen() {
                if (!this.canHover()) return;
                this.open = true;
            },
            canHoverClose() {
                if (!this.canHover()) return;
                this.open = false;
            },
            toggle() {
                this.open = !this.open;
            },
            close() {
                this.open = false;
            }
        }
    }

    window.addEventListener('alpine:init', () => {
        Alpine.data('initMenuDesktop', initMenuDesktop);
        Alpine.data('initMenuDesktopItem', initMenuDesktopItem);
    }, { once: true })
</script>
<?php $hyvaCsp->registerInlineScript() ?>
