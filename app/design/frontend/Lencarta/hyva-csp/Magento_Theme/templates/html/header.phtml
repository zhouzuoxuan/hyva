declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HyvaCsp;
use Hyva\Theme\ViewModel\LucideIcons;
use Hyva\Theme\ViewModel\StoreConfig;
use Magento\Checkout\Block\Cart\Sidebar as SidebarCart;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

/** @var Escaper $escaper */
/** @var Template $block */
/** @var ViewModelRegistry $viewModels */
/** @var HyvaCsp $hyvaCsp */

/** @var LucideIcons $lucideIcons */
$lucideIcons = $viewModels->require(LucideIcons::class);

/** @var StoreConfig $storeConfig */
$storeConfig = $viewModels->require(StoreConfig::class);
$showMiniCart = $storeConfig->getStoreConfig(SidebarCart::XML_PATH_CHECKOUT_SIDEBAR_DISPLAY);

$showCompare = $block->getShowCompare() !== null ? (bool) $block->getShowCompare() : true;
$showWishlist = $block->getShowWishlist() !== null ? (bool) $block->getShowWishlist() : false;
$isHomePage = $block->getRequest()->getFullActionName() === 'cms_index_index';
$headerPositionClass = $isHomePage ? 'fixed inset-x-0 top-0' : 'relative';
?>
<script>
    function initHeader(isHomePage) {
        return {
            searchOpen: false,
            cart: {},
            isCartOpen: false,

            overlayEnabled: isHomePage,
            headerHovered: false,
            scrollY: 0,
            lastScrollY: 0,
            headerHidden: false,
            headerHeight: 0,

            init() {
                this.$nextTick(() => {
                    this.measureHeader();
                    this.onScroll();
                });

                window.addEventListener('resize', () => this.measureHeader(), { passive: true });
            },

            measureHeader() {
                this.headerHeight = this.$root ? this.$root.offsetHeight : 0;
                this.syncHeaderCssVars();
            },

            syncHeaderCssVars() {
                document.documentElement.style.setProperty('--site-header-height', `${this.headerHeight}px`);
                document.documentElement.style.setProperty(
                    '--site-header-offset',
                    this.headerHidden ? '0px' : `${this.headerHeight}px`
                );
            },

            getData(data) {
                this.cart = data.cart ?? {};
            },

            onScroll() {
                const currentScrollY = window.scrollY || document.documentElement.scrollTop || 0;
                const delta = currentScrollY - this.lastScrollY;

                this.scrollY = currentScrollY;

                if (this.searchOpen || this.isCartOpen || this.headerHovered) {
                    this.headerHidden = false;
                    this.lastScrollY = currentScrollY;
                    this.syncHeaderCssVars();
                    return;
                }

                if (currentScrollY <= 8) {
                    this.headerHidden = false;
                    this.lastScrollY = currentScrollY;
                    this.syncHeaderCssVars();
                    return;
                }

                if (currentScrollY > this.headerHeight) {
                    if (delta > 6) {
                        this.headerHidden = true;
                    } else if (delta < -6) {
                        this.headerHidden = false;
                    }
                } else {
                    this.headerHidden = false;
                }

                this.lastScrollY = currentScrollY;
                this.syncHeaderCssVars();
            },

            isOverlayMode() {
                return this.overlayEnabled;
            },

            isSolidHeader() {
                if (!this.isOverlayMode()) {
                    return true;
                }

                if (this.headerHovered || this.searchOpen || this.isCartOpen) {
                    return true;
                }

                return this.scrollY > 24;
            },

            headerClasses() {
                return this.isSolidHeader()
                    ? 'bg-white/95 text-slate-900 border-gray-100 shadow backdrop-blur supports-[backdrop-filter]:bg-white/80'
                    : 'bg-transparent text-white border-transparent shadow-none';
            },

            headerVisibilityClasses() {
                return this.headerHidden
                    ? '-translate-y-full opacity-0 pointer-events-none'
                    : 'translate-y-0 opacity-100';
            },

            searchPanelClasses() {
                return this.isSolidHeader()
                    ? 'border-t border-gray-100 bg-white shadow-sm'
                    : 'border-t border-white/20 bg-black/35 text-white shadow-xl backdrop-blur supports-[backdrop-filter]:bg-black/20';
            },

            navClasses() {
                return this.isSolidHeader() ? 'text-slate-900' : 'text-white';
            },

            actionClasses() {
                return this.isSolidHeader() ? 'text-slate-900' : 'text-white';
            },

            summaryCount() {
                return this.cart.summary_count || 0;
            },

            cartAriaLabel() {
                return '<?= $escaper->escapeJs($showMiniCart ? __('Toggle minicart') : __('View cart')) ?>, ' +
                    (this.isCartEmpty() ? '<?= $escaper->escapeJs(__('Cart is empty')) ?>' : (
                        Math.abs(this.summaryCount()) > 1
                            ? hyva.str('<?= $escaper->escapeJs(__('%1 items')) ?>', this.summaryCount())
                            : hyva.str('<?= $escaper->escapeJs(__('%1 item')) ?>', this.summaryCount())
                    ));
            },

            isCartEmpty() {
                return !this.cart.summary_count;
            },

            toggleCart() {
                this.isCartOpen = this.$event.detail?.isOpen ?? true;
                this.headerHidden = false;
                this.syncHeaderCssVars();
                this.$dispatch('toggle-cart', { isOpen: this.isCartOpen });
            },

            toggleSearch() {
                this.searchOpen = !this.searchOpen;
                this.headerHidden = false;
                this.syncHeaderCssVars();
                this.$dispatch('search-open');
            },

            toggleSearchOpen() {
                this.searchOpen = true;
                this.headerHidden = false;
                this.syncHeaderCssVars();
                this.$dispatch('search-open');
            },

            searchClose() {
                this.searchOpen = false;
                this.syncHeaderCssVars();
                this.$refs.searchButton.focus();
            },

            searchEscape() {
                this.searchClose();
            },

            isMac: /Mac|iPod|iPhone|iPad/.test(navigator.platform),

            textShortcutModifier() {
                return this.isMac ? '⌘ K' : 'Ctrl+K';
            },

            searchShortcut(e) {
                const modifier = this.isMac ? e.metaKey : e.ctrlKey;
                if (modifier && e.key === 'k') {
                    e.preventDefault();
                    this.toggleSearchOpen();
                }
            }
        }
    }

    window.addEventListener('alpine:init', () => {
        Alpine.data('initHeader', () => initHeader(<?= $isHomePage ? 'true' : 'false' ?>));
    }, { once: true });
</script>
<?php $hyvaCsp->registerInlineScript(); ?>

