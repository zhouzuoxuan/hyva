<?php
/** @var \Lencarta\Cms\Block\Widget\HeroBanner $block */
$desktopImage = $block->getField('desktop_image');
$mobileImage = $block->getPictureFallback('mobile_image', 'desktop_image');
$imageAlt = $block->getField('image_alt', $block->getField('title'));
$eyebrow = $block->getField('eyebrow');
$title = $block->getField('title');
$titleTag = $block->getField('title_tag', 'h1');
$descriptionHtml = $block->getHtmlField('description_html');
$buttonText = $block->getField('button_text');
$buttonLink = $block->getField('button_link');
$contentPosition = $block->getField('content_position', 'right-bottom');
$overlayStyle = $block->getField('overlay_style', 'dark');
$overlayOpacity = $block->getField('overlay_opacity', '35');
$textScheme = $block->getField('text_scheme', 'light');
$buttonStyle = $block->getField('button_style', 'primary');
$fullscreen = $block->getBoolField('fullscreen', true);
$showScrollHint = $block->getBoolField('show_scroll_hint', true);

$positionClasses = [
    'left-top' => 'items-start justify-start text-left',
    'left-center' => 'items-center justify-start text-left',
    'left-bottom' => 'items-end justify-start text-left',
    'center-center' => 'items-center justify-center text-center',
    'right-top' => 'items-start justify-end text-left',
    'right-center' => 'items-center justify-end text-left',
    'right-bottom' => 'items-end justify-end text-left',
];
$contentContainerClass = $positionClasses[$contentPosition] ?? $positionClasses['right-bottom'];

$overlayBg = [
    'dark' => 'bg-slate-950',
    'light' => 'bg-white',
    'brand' => 'bg-slate-900',
    'none' => 'bg-transparent',
];
$overlayOpacityClass = [
    '20' => 'opacity-20',
    '35' => 'opacity-35',
    '50' => 'opacity-50',
    '65' => 'opacity-65',
];

$textClasses = $block->getHeroTextSchemeClasses($textScheme);
$buttonClass = $block->getButtonStyleClasses($buttonStyle, 'hero', $textScheme);
$heightClass = $fullscreen ? 'min-h-[100svh]' : 'min-h-[70svh]';
$allowedTitleTags = ['h1', 'h2', 'h3', 'div'];
if (!in_array($titleTag, $allowedTitleTags, true)) {
    $titleTag = 'h1';
}
$titleClass = $textClasses['title'] . ' max-w-[14ch] text-4xl font-semibold leading-[1.02] sm:text-5xl lg:text-6xl';
$descriptionClass = $textClasses['description'] . ' mt-5 max-w-xl text-base leading-7 sm:text-lg [&_a]:underline [&_a]:underline-offset-4 [&_a:hover]:opacity-90';
?>
<?php if ($desktopImage !== ''): ?>
<section class="relative isolate overflow-hidden <?= $block->escapeHtmlAttr($heightClass) ?>">
    <div class="absolute inset-0">
        <picture>
            <?php if ($mobileImage !== '' && $mobileImage !== $desktopImage): ?>
                <source media="(max-width: 767px)" srcset="<?= $block->escapeUrl($mobileImage) ?>">
            <?php endif; ?>
            <img src="<?= $block->escapeUrl($desktopImage) ?>"
                 alt="<?= $block->escapeHtmlAttr($imageAlt) ?>"
                 class="h-full w-full object-cover"
                 fetchpriority="high" />
        </picture>
    </div>

    <?php if ($overlayStyle !== 'none'): ?>
        <div class="absolute inset-0 <?= $block->escapeHtmlAttr(($overlayBg[$overlayStyle] ?? 'bg-slate-950') . ' ' . ($overlayOpacityClass[$overlayOpacity] ?? 'opacity-35')) ?>"></div>
    <?php endif; ?>

    <div class="relative z-10 mx-auto flex <?= $block->escapeHtmlAttr($heightClass . ' ' . $contentContainerClass) ?> px-6 py-10 md:px-10 md:py-14 lg:px-14 lg:py-16">
        <div class="w-full max-w-2xl">
            <?php if ($eyebrow !== ''): ?>
                <div class="mb-4 text-xs font-semibold uppercase tracking-[0.22em] <?= $block->escapeHtmlAttr($textClasses['eyebrow']) ?>">
                    <?= $block->escapeHtml($eyebrow) ?>
                </div>
            <?php endif; ?>

            <?php if ($title !== ''): ?>
                <<?= $block->escapeHtml($titleTag) ?> class="<?= $block->escapeHtmlAttr($titleClass) ?>">
                    <?= $block->escapeHtml($title) ?>
                </<?= $block->escapeHtml($titleTag) ?>>
            <?php endif; ?>

            <?php if ($descriptionHtml !== ''): ?>
                <div class="<?= $block->escapeHtmlAttr($descriptionClass) ?>">
                    <?= /* @noEscape */ $descriptionHtml ?>
                </div>
            <?php endif; ?>

            <?php if ($buttonText !== '' && $buttonLink !== ''): ?>
                <div class="mt-7">
                    <a href="<?= $block->escapeUrl($buttonLink) ?>"
                       class="inline-flex items-center justify-center rounded-xl px-5 py-3 text-sm font-medium transition <?= $block->escapeHtmlAttr($buttonClass) ?>">
                        <?= $block->escapeHtml($buttonText) ?>
                    </a>
                </div>
            <?php endif; ?>
        </div>
    </div>

    <?php if ($showScrollHint): ?>
        <div class="pointer-events-none absolute inset-x-0 bottom-5 z-10 flex justify-center">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/40 text-white/80">
                <span aria-hidden="true">↓</span>
            </span>
        </div>
    <?php endif; ?>
</section>
<?php endif; ?>
