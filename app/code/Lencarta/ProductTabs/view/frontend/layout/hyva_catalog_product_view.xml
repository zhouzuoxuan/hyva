<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="product.info.details">
            <block class="Lencarta\ProductTabs\Block\Product\AttributeTab"
                   name="product.attribute.tab.what_in_the_box"
                   template="Lencarta_ProductTabs::product/attribute-tab.phtml"
                   group="detailed_info">
                <arguments>
                    <argument name="attribute_code" xsi:type="string">what_in_the_box</argument>
                    <argument name="sort_order" xsi:type="number">30</argument>
                </arguments>
            </block>
            <block class="Lencarta\ProductTabs\Block\Product\CmsTab"
                   name="product.cms.tab.delivery_returns"
                   template="Lencarta_ProductTabs::product/cms-tab.phtml"
                   group="detailed_info">
                <arguments>
                    <argument name="cms_identifier" xsi:type="string">delivery_returns_product_tabs</argument>
                    <argument name="sort_order" xsi:type="number">60</argument>
                    <argument name="title" xsi:type="string">Delivery &amp; Returns</argument>
                </arguments>
            </block>

            <!-- <block name="related.tab" class="Magento\Catalog\Block\Product\View"
                   template="Magento_Catalog::product/slider/product-slider.phtml"
                   group="detailed_info">
                <arguments>
                    <argument name="sort_order" xsi:type="number">25</argument>
                    <argument name="type" xsi:type="string">related</argument>
                    <argument name="title" xsi:type="string" translate="true">Related Products</argument>
                    <argument name="heading_tag" xsi:type="string">h2</argument>
                </arguments>
            </block> -->
        </referenceBlock>
    </body>
</page>
