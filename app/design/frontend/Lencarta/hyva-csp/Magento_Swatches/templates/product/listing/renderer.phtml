<?php
declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\SwatchRenderer;
use Magento\Framework\Escaper;
use Magento\Swatches\Block\Product\Renderer\Listing\Configurable;

/** @var Configurable $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */
/** @var \Hyva\Theme\ViewModel\HyvaCsp $hyvaCsp */

// phpcs:disable Generic.Files.LineLength.TooLong

$product = $block->getProduct();
$productId = (int) $product->getId();

$attributes = $block->decorateArray($block->getAllowAttributes());

/** @var SwatchRenderer $swatchRendererViewModel */
$swatchRendererViewModel = $viewModels->require(SwatchRenderer::class);

$layout = $block->getLayout();
$swatchItemBlock = $layout->getBlock('product.swatch.item');

if (!$swatchItemBlock) {
    return;
}

$swatchItemBlock->setData('product_id', $productId);
?>

<?php if ($product->isSaleable() && count($attributes)): ?>
    <script>
        function initConfigurableSwatchOptions_<?= $productId ?>() {
            const configurableOptionsComponent = initConfigurableOptions(
                '<?= $productId ?>',
                <?= /* @noEscape */ $block->getJsonConfig() ?>
            );
            const swatchOptionsComponent = initSwatchOptions(
                <?= /* @noEscape */ $block->getJsonSwatchConfig() ?>
            );

            return Object.assign(
                configurableOptionsComponent,
                swatchOptionsComponent,
                {
                    productId: '<?= $productId ?>',
                    mediaCallback: "<?= $escaper->escapeJs($escaper->escapeUrl($block->getMediaCallback())) ?>",
                    lastListingGalleryProductId: null,
                    lastSelectionSignature: null,

                    getListingAttributeOptions(attributeId) {
                        const options = this.getAllAttributeOptions(attributeId);
                        return Array.isArray(options) ? options : [];
                    },

                    hasListingAttributeOptions(attributeId) {
                        return this.getListingAttributeOptions(attributeId).length > 0;
                    },

                    getListingSelectionSignature() {
                        const selectedValues = this.selectedValues || {};
                        const normalized = {};

                        Object.keys(selectedValues)
                            .sort()
                            .forEach(attributeId => {
                                const value = selectedValues[attributeId];

                                if (value !== null && value !== undefined && value !== '') {
                                    normalized[String(attributeId)] = String(value);
                                }
                            });

                        return JSON.stringify(normalized);
                    },

                    getMatchingProductIdsFromSelectedOptions() {
                        const attributes = this.optionConfig && this.optionConfig.attributes
                            ? this.optionConfig.attributes
                            : {};

                        let matchedProductIds = null;

                        Object.values(attributes).forEach(attribute => {
                            const selectedValues = this.selectedValues || {};
                            const selectedValue =
                                selectedValues[attribute.id] !== undefined
                                    ? selectedValues[attribute.id]
                                    : selectedValues[String(attribute.id)];

                            if (selectedValue === null || selectedValue === undefined || selectedValue === '') {
                                return;
                            }

                            const option = Array.isArray(attribute.options)
                                ? attribute.options.find(option => String(option.id) === String(selectedValue))
                                : null;

                            const optionProductIds = option && Array.isArray(option.products)
                                ? option.products.map(productId => String(productId))
                                : [];

                            if (matchedProductIds === null) {
                                matchedProductIds = optionProductIds;
                                return;
                            }

                            matchedProductIds = matchedProductIds.filter(productId => {
                                return optionProductIds.includes(productId);
                            });
                        });

                        return Array.isArray(matchedProductIds) ? matchedProductIds : [];
                    },

                    getListingGalleryProductId() {
                        if (this.productIndex) {
                            return String(this.productIndex);
                        }

                        const matchedProductIds = this.getMatchingProductIdsFromSelectedOptions();

                        if (matchedProductIds.length) {
                            return matchedProductIds[0];
                        }

                        return null;
                    },

                    syncListingGallery() {
                        const selectionSignature = this.getListingSelectionSignature();

                        if (selectionSignature === this.lastSelectionSignature) {
                            return;
                        }

                        this.lastSelectionSignature = selectionSignature;

                        this.$nextTick(() => {
                            const galleryProductId = this.getListingGalleryProductId();

                            if (!galleryProductId) {
                                this.lastListingGalleryProductId = null;
                                return;
                            }

                            this.fetchListingGallery(galleryProductId);
                        });
                    },

                    fetchListingGallery(galleryProductId) {
                        if (!galleryProductId) {
                            return;
                        }

                        if (String(this.lastListingGalleryProductId) === String(galleryProductId)) {
                            return;
                        }

                        this.lastListingGalleryProductId = String(galleryProductId);

                        fetch(`${this.mediaCallback}?product_id=${encodeURIComponent(galleryProductId)}&isAjax=true`, {
                            method: 'GET',
                            headers: {
                                'Content-Type': 'application/json',
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        })
                            .then(response => {
                                if (!response.ok) {
                                    throw new Error(`HTTP ${response.status}`);
                                }

                                return response.json();
                            })
                            .then(data => {
                                if (data.errors) {
                                    console.warn(data.errors);
                                    return;
                                }

                                const image = data && (data.medium || data.large || data.small)
                                    ? (data.medium || data.large || data.small)
                                    : null;

                                if (image) {
                                    window.dispatchEvent(
                                        new CustomEvent(
                                            "update-gallery-<?= $productId ?>",
                                            { detail: image }
                                        )
                                    );
                                }
                            })
                            .catch(error => {
                                console.warn(error);
                            });
                    },

                    preselectQuerystringItems() {
                        const urlQueryParams = new URLSearchParams(window.location.search.replace('?', ''));
                        const attributes = this.optionConfig && this.optionConfig.attributes
                            ? this.optionConfig.attributes
                            : {};

                        Object.values(attributes).forEach(attribute => {
                            if (urlQueryParams.get(attribute.code) !== null) {
                                let optionId = urlQueryParams.get(attribute.code);

                                if (Array.isArray(attribute.options)) {
                                    attribute.options.forEach(option => {
                                        if (option.label === optionId) {
                                            optionId = option.id;
                                        }
                                    });
                                }

                                this.changeOption(attribute.id, optionId);
                            }
                        });
                    },

                    mouseDown: false,
                    startX: 0,
                    maxScroll: 0,
                    scrollLeft: null,
                    slider: null,

                    scrollEvents: {
                        ['@mousedown'](e) {
                            this.slider = e.target.closest('.snap');

                            if (!this.slider) {
                                return;
                            }

                            this.maxScroll = this.slider.scrollWidth - this.slider.offsetWidth;
                            this.startX = e.pageX - this.slider.offsetLeft;
                            this.scrollLeft = this.slider.scrollLeft;
                            this.mouseDown = true;
                        },

                        ['@mouseout.self']() {
                            this.mouseDown = false;
                        },

                        ['@mouseup']() {
                            this.mouseDown = false;
                        },

                        ['@mousemove'](e) {
                            e.preventDefault();

                            if (!this.mouseDown) {
                                return;
                            }

                            const x = e.pageX - this.slider.offsetLeft;
                            const scroll = x - this.startX;
                            const scrollLeft = this.scrollLeft - scroll;

                            if (scrollLeft > this.maxScroll) {
                                this.slider.scrollLeft = this.maxScroll;
                                return;
                            }

                            this.slider.scrollLeft = this.scrollLeft - scroll;
                        },

                        ['@onselectstart']() {
                            return false;
                        }
                    },

                    resizeEvent() {
                        Array.from(this.$el.querySelectorAll('.snap')).forEach(slider => {
                            slider.scrollLeft = 0;
                        });
                    }
                }
            );
        }
    </script>
    <?php $hyvaCsp->registerInlineScript(); ?>

    <div
        x-data="initConfigurableSwatchOptions_<?= $productId ?>()"
        x-init="findAllowedAttributeOptions();"
        x-effect="syncListingGallery()"
        @private-content-loaded.window="onGetCartData($event.detail.data)"
        @resize.window="resizeEvent()"
        class="mb-2 relative"
        data-product-id="<?= $productId ?>"
    >
        <div>
            <?php foreach ($attributes as $attribute): ?>
                <?php
                $attributeId = (int) $attribute->getAttributeId();
                $productAttribute = $attribute->getProductAttribute();
                ?>

                <?php if (
                    !$productAttribute->getUsedInProductListing()
                    || !$swatchRendererViewModel->isSwatchAttribute($productAttribute)
                ) {
                    continue;
                } ?>

                <div
                    class="swatch-attribute border-t last:border-b border-container <?= $escaper->escapeHtmlAttr($productAttribute->getAttributeCode()) ?>"
                >
                    <div class="w-full overflow-x-hidden swatch-attribute-options">
                        <div
                            class="flex flex-nowrap w-full overflow-auto transition-all snap items-center py-1 min-h-14"
                            role="radiogroup"
                            x-spread="scrollEvents"
                            aria-label="<?= $escaper->escapeHtml($productAttribute->getStoreLabel()) ?>"
                        >
                            <template x-if="hasListingAttributeOptions(<?= $attributeId ?>)">
                                <template
                                    x-for="(item, index) in getListingAttributeOptions(<?= $attributeId ?>)"
                                    :key="item.id"
                                >
                                    <?= /* @noEscape */ $swatchItemBlock->setData('attribute_id', $attributeId)->toHtml(); ?>
                                </template>
                            </template>
                        </div>
                    </div>
                </div>
            <?php endforeach; ?>
        </div>
    </div>
<?php endif; ?>
