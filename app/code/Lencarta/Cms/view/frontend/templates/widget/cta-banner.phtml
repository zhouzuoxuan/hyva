<?php
/** @var \Lencarta\Cms\Block\Widget\CtaBanner $block */
$title = (string) $block->getData('title');
$content = (string) $block->getData('content');
$buttonLabel = (string) $block->getData('button_label');
$buttonUrl = (string) $block->getData('button_url');
$themeVariant = (string) ($block->getData('theme_variant') ?: 'dark');
$wrapperClass = [
    'light' => 'bg-white border border-gray-200',
    'soft' => 'bg-gray-50',
    'dark' => 'bg-black text-white',
][$themeVariant] ?? 'bg-black text-white';
$textClass = $themeVariant === 'dark' ? 'text-gray-200' : 'text-gray-700';
$buttonClass = $themeVariant === 'dark' ? 'bg-white text-black hover:bg-gray-100' : 'bg-black text-white hover:opacity-90';
?>
<?php if ($title !== ''): ?>
    <section class="rounded-2xl p-6 md:p-8 <?= $block->escapeHtmlAttr($wrapperClass) ?>">
        <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
            <div class="max-w-2xl">
                <h2 class="text-2xl font-semibold leading-tight md:text-3xl"><?= $block->escapeHtml($title) ?></h2>
                <?php if ($content !== ''): ?>
                    <div class="mt-3 text-sm leading-7 md:text-base <?= $block->escapeHtmlAttr($textClass) ?>">
                        <?= nl2br($block->escapeHtml($content)) ?>
                    </div>
                <?php endif; ?>
            </div>
            <?php if ($buttonLabel !== '' && $buttonUrl !== ''): ?>
                <div>
                    <a href="<?= $block->escapeUrl($buttonUrl) ?>"
                       class="inline-flex items-center justify-center rounded-lg px-5 py-3 text-sm font-medium transition <?= $block->escapeHtmlAttr($buttonClass) ?>">
                        <?= $block->escapeHtml($buttonLabel) ?>
                    </a>
                </div>
            <?php endif; ?>
        </div>
    </section>
<?php endif; ?>
