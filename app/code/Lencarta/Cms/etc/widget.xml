<?xml version="1.0"?>
<widgets xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Widget:etc/widget.xsd">

    <widget id="lencarta_content_section"
            class="Lencarta\Cms\Block\Widget\ContentSection"
            is_email_compatible="true"
            placeholder_image="Magento_Cms::images/widget_pagebuilder.png">
        <label translate="true">Lencarta - Content Section</label>
        <description translate="true">Reusable content section with friendlier content and image inputs.</description>
        <parameters>
            <parameter name="eyebrow" xsi:type="text" visible="true" required="false" sort_order="10">
                <label translate="true">Eyebrow</label>
            </parameter>
            <parameter name="title" xsi:type="text" visible="true" required="true" sort_order="20">
                <label translate="true">Title</label>
            </parameter>
            <parameter name="content" xsi:type="block" visible="true" required="false" sort_order="30">
                <label translate="true">Intro Text / HTML</label>
                <description translate="true">Supports multiple lines and basic HTML such as &lt;br&gt;, &lt;strong&gt;, &lt;em&gt; and links.</description>
                <block class="Lencarta\Cms\Block\Adminhtml\Widget\Field\Textarea"/>
            </parameter>
            <parameter name="button_label" xsi:type="text" visible="true" required="false" sort_order="40">
                <label translate="true">Button Text</label>
            </parameter>
            <parameter name="button_url" xsi:type="text" visible="true" required="false" sort_order="50">
                <label translate="true">Button Link</label>
            </parameter>
            <parameter name="image_url" xsi:type="block" visible="true" required="false" sort_order="60">
                <label translate="true">Image</label>
                <description translate="true">Choose an image from the media gallery or paste a media URL.</description>
                <block class="Lencarta\Cms\Block\Adminhtml\Widget\Field\ImageChooser">
                    <data>
                        <item name="button" xsi:type="array">
                            <item name="open" xsi:type="string">Choose Image...</item>
                        </item>
                    </data>
                </block>
            </parameter>
            <parameter name="image_alt" xsi:type="text" visible="true" required="false" sort_order="70">
                <label translate="true">Image Alt Text</label>
            </parameter>
            <parameter name="media_position" xsi:type="select" visible="true" required="false" sort_order="80" source_model="Lencarta\Cms\Model\Config\Source\MediaPosition">
                <label translate="true">Image Position</label>
            </parameter>
            <parameter name="theme_variant" xsi:type="select" visible="true" required="false" sort_order="90" source_model="Lencarta\Cms\Model\Config\Source\ThemeVariant">
                <label translate="true">Section Style</label>
            </parameter>
        </parameters>
    </widget>

    <widget id="lencarta_usp_list"
            class="Lencarta\Cms\Block\Widget\UspList"
            is_email_compatible="true"
            placeholder_image="Magento_Cms::images/widget_pagebuilder.png">
        <label translate="true">Lencarta - USP List</label>
        <description translate="true">USP list with repeatable rows in admin.</description>
        <parameters>
            <parameter name="title" xsi:type="text" visible="true" required="false" sort_order="10">
                <label translate="true">Title</label>
            </parameter>
            <parameter name="items" xsi:type="block" visible="true" required="true" sort_order="20">
                <label translate="true">USP Items</label>
                <description translate="true">Add one USP per row. The value is stored as JSON but remains backward compatible with line-based input.</description>
                <block class="Lencarta\Cms\Block\Adminhtml\Widget\Field\Repeater">
                    <data>
                        <item name="button_label" xsi:type="string">Add USP Item</item>
                        <item name="empty_text" xsi:type="string">No USP items added yet.</item>
                        <item name="row_placeholder" xsi:type="string">Enter USP text</item>
                    </data>
                </block>
            </parameter>
            <parameter name="columns" xsi:type="select" visible="true" required="false" sort_order="30" source_model="Lencarta\Cms\Model\Config\Source\Columns">
                <label translate="true">Columns</label>
            </parameter>
        </parameters>
    </widget>

    <widget id="lencarta_cta_banner"
            class="Lencarta\Cms\Block\Widget\CtaBanner"
            is_email_compatible="true"
            placeholder_image="Magento_Cms::images/widget_pagebuilder.png">
        <label translate="true">Lencarta - CTA Banner</label>
        <description translate="true">CTA banner with optional desktop/mobile images, overlay and content positioning.</description>
        <parameters>
            <parameter name="eyebrow" xsi:type="text" visible="true" required="false" sort_order="10">
                <label translate="true">Eyebrow</label>
            </parameter>
            <parameter name="title" xsi:type="text" visible="true" required="true" sort_order="20">
                <label translate="true">Title</label>
            </parameter>
            <parameter name="content" xsi:type="block" visible="true" required="false" sort_order="30">
                <label translate="true">Content / HTML</label>
                <block class="Lencarta\Cms\Block\Adminhtml\Widget\Field\Textarea"/>
            </parameter>
            <parameter name="button_label" xsi:type="text" visible="true" required="false" sort_order="40">
                <label translate="true">Button Text</label>
            </parameter>
            <parameter name="button_url" xsi:type="text" visible="true" required="false" sort_order="50">
                <label translate="true">Button Link</label>
            </parameter>
            <parameter name="desktop_image" xsi:type="block" visible="true" required="false" sort_order="60">
                <label translate="true">Desktop Banner Image</label>
                <block class="Lencarta\Cms\Block\Adminhtml\Widget\Field\ImageChooser">
                    <data>
                        <item name="button" xsi:type="array">
                            <item name="open" xsi:type="string">Choose Desktop Image...</item>
                        </item>
                    </data>
                </block>
            </parameter>
            <parameter name="mobile_image" xsi:type="block" visible="true" required="false" sort_order="70">
                <label translate="true">Mobile Banner Image</label>
                <description translate="true">Optional. Falls back to the desktop image when empty.</description>
                <block class="Lencarta\Cms\Block\Adminhtml\Widget\Field\ImageChooser">
                    <data>
                        <item name="button" xsi:type="array">
                            <item name="open" xsi:type="string">Choose Mobile Image...</item>
                        </item>
                    </data>
                </block>
            </parameter>
            <parameter name="image_alt" xsi:type="text" visible="true" required="false" sort_order="80">
                <label translate="true">Image Alt Text</label>
            </parameter>
            <parameter name="content_position" xsi:type="select" visible="true" required="false" sort_order="90" source_model="Lencarta\Cms\Model\Config\Source\ContentPosition">
                <label translate="true">Content Position</label>
            </parameter>
            <parameter name="overlay_style" xsi:type="select" visible="true" required="false" sort_order="100" source_model="Lencarta\Cms\Model\Config\Source\OverlayStyle">
                <label translate="true">Overlay Style</label>
            </parameter>
            <parameter name="overlay_opacity" xsi:type="select" visible="true" required="false" sort_order="110" source_model="Lencarta\Cms\Model\Config\Source\OverlayOpacity">
                <label translate="true">Overlay Opacity</label>
            </parameter>
            <parameter name="text_scheme" xsi:type="select" visible="true" required="false" sort_order="120" source_model="Lencarta\Cms\Model\Config\Source\TextScheme">
                <label translate="true">Text Colour Scheme</label>
            </parameter>
            <parameter name="theme_variant" xsi:type="select" visible="true" required="false" sort_order="130" source_model="Lencarta\Cms\Model\Config\Source\ThemeVariant">
                <label translate="true">Fallback Style (No Image)</label>
            </parameter>
        </parameters>
    </widget>

    <widget id="lencarta_homepage_hero_banner"
            class="Lencarta\Cms\Block\Widget\HeroBanner"
            is_email_compatible="true"
            placeholder_image="Magento_Cms::images/widget_pagebuilder.png">
        <label translate="true">Lencarta - Homepage Hero Banner</label>
        <description translate="true">Full-screen homepage hero with desktop/mobile images, HTML description, overlay and content position control.</description>
        <parameters>
            <parameter name="desktop_image" xsi:type="block" visible="true" required="true" sort_order="10">
                <label translate="true">Desktop Background Image</label>
                <block class="Lencarta\Cms\Block\Adminhtml\Widget\Field\ImageChooser">
                    <data>
                        <item name="button" xsi:type="array">
                            <item name="open" xsi:type="string">Choose Desktop Image...</item>
                        </item>
                    </data>
                </block>
            </parameter>
            <parameter name="mobile_image" xsi:type="block" visible="true" required="false" sort_order="20">
                <label translate="true">Mobile Background Image</label>
                <description translate="true">Optional. Falls back to the desktop image when empty.</description>
                <block class="Lencarta\Cms\Block\Adminhtml\Widget\Field\ImageChooser">
                    <data>
                        <item name="button" xsi:type="array">
                            <item name="open" xsi:type="string">Choose Mobile Image...</item>
                        </item>
                    </data>
                </block>
            </parameter>
            <parameter name="image_alt" xsi:type="text" visible="true" required="false" sort_order="30">
                <label translate="true">Image Alt Text</label>
            </parameter>
            <parameter name="eyebrow" xsi:type="text" visible="true" required="false" sort_order="40">
                <label translate="true">Eyebrow</label>
            </parameter>
            <parameter name="title" xsi:type="text" visible="true" required="true" sort_order="50">
                <label translate="true">Title</label>
            </parameter>
            <parameter name="description_html" xsi:type="block" visible="true" required="false" sort_order="60">
                <label translate="true">Description (HTML)</label>
                <description translate="true">Supports HTML such as &lt;br&gt;, &lt;strong&gt;, &lt;em&gt;, &lt;span&gt; and links.</description>
                <block class="Lencarta\Cms\Block\Adminhtml\Widget\Field\Textarea">
                    <data>
                        <item name="rows" xsi:type="string">8</item>
                    </data>
                </block>
            </parameter>
            <parameter name="button_text" xsi:type="text" visible="true" required="false" sort_order="70">
                <label translate="true">Button Text</label>
            </parameter>
            <parameter name="button_link" xsi:type="text" visible="true" required="false" sort_order="80">
                <label translate="true">Button Link</label>
            </parameter>
            <parameter name="content_position" xsi:type="select" visible="true" required="false" sort_order="90" source_model="Lencarta\Cms\Model\Config\Source\ContentPosition">
                <label translate="true">Content Position</label>
            </parameter>
            <parameter name="overlay_style" xsi:type="select" visible="true" required="false" sort_order="100" source_model="Lencarta\Cms\Model\Config\Source\OverlayStyle">
                <label translate="true">Overlay Style</label>
            </parameter>
            <parameter name="overlay_opacity" xsi:type="select" visible="true" required="false" sort_order="110" source_model="Lencarta\Cms\Model\Config\Source\OverlayOpacity">
                <label translate="true">Overlay Opacity</label>
            </parameter>
            <parameter name="text_scheme" xsi:type="select" visible="true" required="false" sort_order="120" source_model="Lencarta\Cms\Model\Config\Source\TextScheme">
                <label translate="true">Text Colour Scheme</label>
            </parameter>
            <parameter name="fullscreen" xsi:type="select" visible="true" required="false" sort_order="130" source_model="Magento\Config\Model\Config\Source\Yesno">
                <label translate="true">Full Screen Hero</label>
            </parameter>
            <parameter name="show_scroll_hint" xsi:type="select" visible="true" required="false" sort_order="140" source_model="Magento\Config\Model\Config\Source\Yesno">
                <label translate="true">Show Scroll Hint</label>
            </parameter>
        </parameters>
    </widget>

</widgets>
