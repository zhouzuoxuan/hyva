<?php
declare(strict_types=1);

use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

/** @var Template $block */
/** @var Escaper $escaper */

$title = trim((string) $block->getData('title'));
$items = method_exists($block, 'getItemsList') ? $block->getItemsList() : [];

if ($title === '' && $items === []) {
    return;
}

$gridClass = method_exists($block, 'getGridColumnsClass') ? $block->getGridColumnsClass() : 'md:grid-cols-3';
?>
<section class="my-8 rounded-2xl bg-gray-50 px-6 py-8 md:px-8 md:py-10">
    <?php if ($title !== ''): ?>
        <h2 class="mb-6 text-2xl font-semibold leading-tight md:text-3xl">
            <?= $escaper->escapeHtml($title) ?>
        </h2>
    <?php endif; ?>

    <?php if ($items !== []): ?>
        <div class="grid gap-4 <?= $escaper->escapeHtmlAttr($gridClass) ?>">
            <?php foreach ($items as $item): ?>
                <div class="rounded-xl border border-gray-200 bg-white px-4 py-4 text-sm leading-6 text-gray-800">
                    <span class="font-semibold">•</span>
                    <?= $escaper->escapeHtml($item) ?>
                </div>
            <?php endforeach; ?>
        </div>
    <?php endif; ?>
</section>
