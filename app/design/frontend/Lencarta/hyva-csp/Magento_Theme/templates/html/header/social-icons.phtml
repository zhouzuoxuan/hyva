declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\SvgIcons;
use Lencarta\Header\ViewModel\HeaderConfig;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

/** @var Template $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */

/** @var SvgIcons $hyvaIcons */
$hyvaIcons = $viewModels->require(SvgIcons::class);

/** @var HeaderConfig $headerConfig */
$headerConfig = $viewModels->require(HeaderConfig::class);

$socials = $headerConfig->getSocialLinks();

if (!$socials) {
    return '';
}
?>

<nav aria-label="<?= $escaper->escapeHtmlAttr(__('Social')) ?>" class="flex flex-wrap justify-center gap-2 px-6 pb-4 pt-6">
    <?php foreach ($socials as $item): ?>
        <a
            href="<?= $escaper->escapeUrl($item['url']) ?>"
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-full bg-slate-700 text-white transition-colors hover:bg-slate-500"
        >
            <?= $hyvaIcons->renderHtml($item['icon'], '', 40, 40, ['title' => __('Follow us on %1', $item['label'])]) ?>
        </a>
    <?php endforeach; ?>
</nav>
