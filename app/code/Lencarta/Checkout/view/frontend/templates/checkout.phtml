<?php
declare(strict_types=1);

use Lencarta\Checkout\ViewModel\CheckoutState;

/** @var \Magento\Framework\View\Element\Template $block */
/** @var CheckoutState|null $viewModel */
$viewModel = $block->getData('view_model');

$homeUrl = $block->getUrl('');
$fallbackLogo = $block->getViewFileUrl('images/logo.svg');

$logoBlock = $block->getLayout()->createBlock(\Magento\Theme\Block\Html\Header\Logo::class);
$logoSrc = $logoBlock ? (string) $logoBlock->getLogoSrc() : '';
$logoAlt = $logoBlock ? (string) $logoBlock->getLogoAlt() : 'Logo';

if ($logoSrc === '') {
    $logoSrc = $fallbackLogo;
}
if ($logoAlt === '') {
    $logoAlt = 'Logo';
}

$initialState = $viewModel ? $viewModel->getInitialState() : [];
$countryOptions = $viewModel ? $viewModel->getCountryOptions() : [];
$addressFieldConfig = $viewModel ? $viewModel->getAddressFieldConfig() : [];

$initialStateJson = json_encode(
    $initialState,
    JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT
);

$countryOptionsJson = json_encode(
    $countryOptions,
    JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT
);

$addressFieldConfigJson = json_encode(
    $addressFieldConfig,
    JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT
);
?>
<script>
    window.lencartaCheckoutConfig = {
        urls: {
            state: '<?= $block->escapeJs($block->getUrl('lencarta_checkout/ajax/checkoutState')) ?>',
            saveEmail: '<?= $block->escapeJs($block->getUrl('lencarta_checkout/ajax/saveEmail')) ?>',
            saveShippingAddress: '<?= $block->escapeJs($block->getUrl('lencarta_checkout/ajax/saveShippingAddress')) ?>',
            saveShippingMethod: '<?= $block->escapeJs($block->getUrl('lencarta_checkout/ajax/saveShippingMethod')) ?>',
            getTotals: '<?= $block->escapeJs($block->getUrl('lencarta_checkout/ajax/getTotals')) ?>'
        },
        homeUrl: '<?= $block->escapeJs($homeUrl) ?>',
        logoSrc: '<?= $block->escapeJs($logoSrc) ?>',
        logoAlt: '<?= $block->escapeJs($logoAlt) ?>',
        initialState: <?= /* @noEscape */ $initialStateJson ?: '{}' ?>,
        countryOptions: <?= /* @noEscape */ $countryOptionsJson ?: '[]' ?>,
        addressFieldConfig: <?= /* @noEscape */ $addressFieldConfigJson ?: '{}' ?>
    };
</script>

<div x-data="initLencartaCheckout(window.lencartaCheckoutConfig)"
     x-init="init()"
     class="min-h-screen bg-white text-slate-900">

    <div class="mx-auto max-w-[1480px] px-4 sm:px-6 lg:px-8 xl:px-10 2xl:px-12">
        <div class="grid min-h-screen grid-cols-1 gap-y-8 lg:grid-cols-[minmax(0,1.55fr)_minmax(360px,0.95fr)] lg:gap-x-8 xl:gap-x-10">

            <!-- LEFT -->
            <section class="min-w-0 bg-white">
                <div class="py-8 lg:py-10">
                    <?= $block->getChildHtml('left_logo') ?>
                    <?= $block->getChildHtml('left_contact') ?>
                    <?= $block->getChildHtml('left_shipping_address') ?>
                    <?= $block->getChildHtml('left_delivery_options') ?>
                    <?= $block->getChildHtml('left_payment_method') ?>
                </div>
            </section>

            <!-- RIGHT -->
            <aside class="min-w-0 bg-[#f8f9fb] lg:border-l lg:border-slate-200"
                   style="box-shadow: 100vw 0 0 100vw #f8f9fb; clip-path: inset(0 -100vw 0 0);">
                <div class="lg:sticky lg:top-0">
                    <div class="px-4 py-8 sm:px-5 lg:px-6 lg:py-10 xl:px-7">
                        <?= $block->getChildHtml('right_summary') ?>
                        <?= $block->getChildHtml('right_products') ?>
                        <?= $block->getChildHtml('right_coupon') ?>
                        <?= $block->getChildHtml('right_totals') ?>
                        <?= $block->getChildHtml('right_cta') ?>
                    </div>
                </div>
            </aside>

        </div>
    </div>
</div>
